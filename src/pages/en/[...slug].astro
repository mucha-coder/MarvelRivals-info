---
// 英語記事詳細ページ
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

// 静的パス生成
export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ id }) => id.startsWith('en/'));
  
  return posts.map((post) => {
    const slug = post.slug.replace(/^en\//, '');
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();
const t = useTranslations('en');

// 対応する日本語記事があるか確認
const allPosts = await getCollection('posts');
const jaSlug = post.slug.replace(/^en\//, '');
const hasJapaneseVersion = allPosts.some((p) => p.slug === `ja/${jaSlug}`);

// 日付フォーマット
const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// カテゴリ
const categoryColors: Record<string, string> = {
  'patch-notes': 'bg-yellow-400 text-black',
  'hero-balance': 'bg-purple-500 text-white',
  'events': 'bg-blue-500 text-white',
  'guides': 'bg-green-500 text-white',
};
const categoryColor = categoryColors[post.data.category] || 'bg-gray-500 text-white';
const categoryKey = `category.${post.data.category}` as keyof ReturnType<typeof useTranslations>;
const categoryLabel = t(categoryKey);

// Get related articles
const enPosts = allPosts.filter((p) => p.id.startsWith('en/') && p.slug !== post.slug);
const relatedPosts = post.data.category === 'patch-notes'
  ? enPosts.filter((p) => p.data.category === 'patch-notes')
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 4)
  : enPosts
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 4);
---

<BaseLayout 
  title={post.data.title} 
  description={post.data.description} 
  lang="en"
  heroImage={post.data.heroImage}
>
  <article class="mx-auto max-w-4xl px-4 sm:px-6 py-8 sm:py-12">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-400">
      <a href="/en" class="hover:text-yellow-400 transition-colors">Home</a>
      <span class="mx-2 text-gray-600">›</span>
      <span class="text-gray-300">{categoryLabel}</span>
    </nav>

    <!-- Article Header -->
    <header class="mb-8">
      <!-- Category Badge -->
      <span class:list={['inline-block px-3 py-1 rounded text-xs font-bold uppercase tracking-wide mb-4', categoryColor]}>
        {categoryLabel}
      </span>
      
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4 leading-tight">
        {post.data.title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400">
        <time datetime={post.data.pubDate.toISOString()}>
          {dateFormatter.format(post.data.pubDate)}
        </time>
        
        {post.data.updatedDate && (
          <span class="text-yellow-400">
            (Updated: {dateFormatter.format(post.data.updatedDate)})
          </span>
        )}
      </div>
      
      <!-- Related Heroes -->
      {post.data.heroes && post.data.heroes.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.heroes.map((hero) => {
            const heroKey = `hero.${hero}` as any;
            const heroName = t(heroKey) || hero;
            return (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-white/10 text-gray-300">
                {heroName}
              </span>
            );
          })}
        </div>
      )}
      
      <!-- Japanese Version Link -->
      {hasJapaneseVersion && (
        <div class="mt-4">
          <a
            href={`/${jaSlug}`}
            class="inline-flex items-center gap-2 text-sm text-yellow-400 hover:text-yellow-300 transition-colors"
          >
            <span>→ 日本語で読む</span>
          </a>
        </div>
      )}
    </header>
    
    <!-- Hero Image -->
    {post.data.heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img
          src={post.data.heroImage}
          alt=""
          class="w-full h-auto"
        />
      </div>
    )}
    
    <!-- Article Content -->
    <div class="prose prose-lg prose-invert max-w-none">
      <Content />
    </div>
    
    <!-- More Articles -->
    {relatedPosts.length > 0 && (
      <section class="mt-12 pt-8 border-t border-white/10">
        <h2 class="text-xl font-bold text-white mb-6">
          {post.data.category === 'patch-notes' ? 'More Patch Notes' : 'More Articles'}
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {relatedPosts.map((related) => {
            const relatedSlug = related.slug.replace(/^en\//, '');
            const relatedCategoryColor = categoryColors[related.data.category] || 'bg-gray-500 text-white';
            const relatedCategoryKey = `category.${related.data.category}` as any;
            return (
              <a href={`/en/${relatedSlug}`} class="group block bg-white/5 rounded-xl overflow-hidden border border-white/10 hover:border-yellow-400/50 transition-all">
                {related.data.heroImage && (
                  <img src={related.data.heroImage} alt="" class="w-full h-32 object-cover" />
                )}
                <div class="p-4">
                  <span class:list={['inline-block px-2 py-0.5 rounded text-xs font-bold uppercase mb-2', relatedCategoryColor]}>
                    {t(relatedCategoryKey)}
                  </span>
                  <h3 class="text-sm font-bold text-white group-hover:text-yellow-400 transition-colors line-clamp-2">
                    {related.data.title}
                  </h3>
                  <time class="text-xs text-gray-500 mt-1 block" datetime={related.data.pubDate.toISOString()}>
                    {dateFormatter.format(related.data.pubDate)}
                  </time>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Back to Home -->
    <footer class="mt-8 pt-8 border-t border-white/10">
      <a
        href="/en"
        class="inline-flex items-center text-sm text-gray-400 hover:text-yellow-400 transition-colors"
      >
        ← Back to all articles
      </a>
    </footer>
  </article>
</BaseLayout>
